# ============================================================
# AI Workout Coach — environment variables
# Copy to .env and fill in your keys
# ============================================================

# --- FPT Cloud (embedding + reranking) ---
FPT_API_KEY=
FPT_BASE_URL=https://mkp-api.fptcloud.com/v1
FPT_EMBEDDING_MODEL=multilingual-e5-large
FPT_EMBEDDING_DIMENSIONS=1024
FPT_RERANKER_MODEL=bge-reranker-v2-m3

# --- OpenAI (chat completion + tool calling + judge) ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o

# --- Qdrant (vector database) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=fitness_kb

# --- RAG retrieval tuning ---
# How many ANN candidates to pull from Qdrant before reranking.
RAG_TOP_K_RETRIEVE=20
# How many top candidates to keep after FPT reranking — these go into the LLM prompt.
RAG_TOP_K_RERANK=7
# Confidence cutoff on the top rerank score. Below this, rag_search reports
# confidence="low" so the agent can acknowledge weak retrieval instead of
# answering confidently from a poor match.
RAG_RERANK_THRESHOLD=0.3

# --- LLM sampling (applies to generation: RAG answer, analysis insight, agent loop) ---
# Classifier and LLM-as-judge stay at temperature 0 for deterministic outputs
# regardless of these values.
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.95

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
